# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used, it can be ignored:
#Pipfile.lock

# poetry
#   Poetry uses pyproject.toml and poetry.lock. Under normal circumstances,
#   poetry.lock should be committed to VCS. If not wanted:
#poetry.lock

# pdm
#   PDM stores local configuration in .pdm.toml
.pdm.toml
.pdm-plugins/

